{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pitch.dog/type-set/type-system.schema.json",
  "title": "Type Set typography system",
  "type": "object",
  "required": ["id", "name", "status", "storyIds", "roles", "character", "fit", "failureCases", "oneThingNotToDo", "scales", "fallbackStack", "evidenceIds", "reviewedOn"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "storyIds": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
    "status": { "enum": ["candidate", "testing", "verified", "limited", "rejected", "stale"] },
    "roles": {
      "type": "object",
      "required": ["display", "body", "utility"],
      "properties": {
        "display": { "$ref": "#/$defs/role" },
        "body": { "$ref": "#/$defs/role" },
        "utility": { "$ref": "#/$defs/role" }
      },
      "additionalProperties": false
    },
    "character": { "enum": ["quiet", "present", "expressive"] },
    "fit": {
      "type": "object",
      "required": ["artifacts", "density", "data", "writingSystems", "applications", "handoffPaths", "viewingContexts"],
      "properties": {
        "artifacts": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "density": { "type": "array", "items": { "enum": ["sparse", "moderate", "dense", "varied"] }, "uniqueItems": true },
        "data": { "enum": ["none", "light", "strong"] },
        "writingSystems": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "applications": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "handoffPaths": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "viewingContexts": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      },
      "additionalProperties": false
    },
    "failureCases": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "oneThingNotToDo": { "type": "string" },
    "scales": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["display", "title", "body", "utility"],
        "properties": {
          "display": { "$ref": "#/$defs/setting" },
          "title": { "$ref": "#/$defs/setting" },
          "body": { "$ref": "#/$defs/setting" },
          "utility": { "$ref": "#/$defs/setting" }
        },
        "additionalProperties": false
      }
    },
    "fallbackStack": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "evidenceIds": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
    "reviewedOn": { "type": "string", "format": "date" }
  },
  "$defs": {
    "role": {
      "type": "object",
      "required": ["fontId", "weight", "style"],
      "properties": {
        "fontId": { "type": "string" },
        "weight": { "type": "integer", "minimum": 1, "maximum": 1000 },
        "style": { "enum": ["normal", "italic"] },
        "features": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      },
      "additionalProperties": false
    },
    "setting": {
      "type": "object",
      "required": ["sizePt", "lineHeight", "trackingEm", "maxCharacters"],
      "properties": {
        "sizePt": { "type": "number", "exclusiveMinimum": 0 },
        "lineHeight": { "type": "number", "exclusiveMinimum": 0 },
        "trackingEm": { "type": "number" },
        "maxCharacters": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
