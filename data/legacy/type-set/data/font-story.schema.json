{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pitch.dog/type-set/font-story.schema.json",
  "title": "Type Set font story",
  "type": "object",
  "required": ["id", "fontId", "creditLine", "people", "origin", "pitchDogView", "whyHere", "limits", "primarySources", "supportUrl", "reviewedOn"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "fontId": { "type": "string", "minLength": 1 },
    "creditLine": { "type": "string", "minLength": 1 },
    "people": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "role"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "origin": { "type": "string", "minLength": 1 },
    "pitchDogView": { "type": "string", "minLength": 1 },
    "whyHere": { "type": "string", "minLength": 1 },
    "limits": { "type": "string", "minLength": 1 },
    "primarySources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["label", "url"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" }
        },
        "additionalProperties": false
      }
    },
    "supportUrl": { "type": "string", "format": "uri" },
    "reviewedOn": { "type": "string", "format": "date" }
  },
  "additionalProperties": false
}
